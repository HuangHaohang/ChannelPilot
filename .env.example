APP_ENV=development
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/channelpilot
INTERNAL_API_TOKEN=channelpilot-internal-token
DEFAULT_BACKEND=codex
LEASE_SECONDS=30
RECONCILE_INTERVAL_SECONDS=15
STUCK_THRESHOLD_SECONDS=180
CANCEL_GRACE_SECONDS=20
MAX_PROGRESS_MESSAGE_FREQUENCY_SECONDS=300
WORKSPACE_ROOT=/var/lib/channelpilot/workspaces
ARTIFACT_ROOT=/var/lib/channelpilot/artifacts
AUTHORIZED_OPERATOR_IDS=telegram:uid:123456
PERMITTED_REPOS=payments,billing,auth-service
MOCK_OPENCLAW_STATE_FILE=.data/mock-openclaw-state.json
WORKER_REGISTRY_URL=http://localhost:4301
API_BASE_URL=http://localhost:4300
MOCK_WORKER_FLOW=completed
MOCK_WORKER_AVAILABILITY=idle
